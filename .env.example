# Copy this file to .env in the target repository where you run
# develop-review-loop. The script reads ./.env from the current working
# directory, not from this tool repository, unless this repository is the target.

# Agent used for the implementation/fix stage. Supported: claude, codex.
# If this variable is also exported in the shell, the exported value wins.
# Default: claude
DEV_AGENT=claude

# Agent used for the review stage. Supported: claude, codex.
# If this variable is also exported in the shell, the exported value wins.
# Default: codex
REVIEW_AGENT=codex

# Path to the codex CLI. Override only if not on $PATH.
# If this variable is also exported in the shell, the exported value wins.
CODEX_BIN=codex

# Path to the claude CLI. Override only if not on $PATH.
# If this variable is also exported in the shell, the exported value wins.
CLAUDE_BIN=claude

# Number of run artifact subdirectories to keep under .develop-review-loop/.
# The current run counts toward this limit. Must be a positive integer.
# If this variable is also exported in the shell, the exported value wins.
# Default: 3
DEVELOP_REVIEW_LOOP_KEEP_RUNS=3
