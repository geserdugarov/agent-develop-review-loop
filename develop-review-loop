#!/usr/bin/env bash
set -euo pipefail

# Force C locale so awk/printf produce dots (not commas) in decimal output and
# sort orders are stable regardless of the user's locale.
export LC_ALL=C

usage() {
  cat >&2 <<'EOF'
Usage: develop-review-loop <task-file> [--max N] [--start-stage development|review]
       develop-review-loop --manual-rerun <run-dir> [--max N] [--rerun-from development-N|review-N]

  <task-file>   Path to a markdown/plain-text file describing the task.
                Contents are passed verbatim to the development agent on iteration 0.
  --max N       Iteration cap (default: 10).
  --start-stage development|review
                Stage to start from (default: development). Use review when
                changes are already present in the work tree.
  --start-review, --review-first
                Alias for --start-stage review.
  --manual-rerun <run-dir>
                Reuse an interrupted .develop-review-loop/run-* directory.
                The first incomplete stage is inferred from phases.tsv.
  --rerun-from development-N|review-N
                Override the inferred rerun stage for --manual-rerun.
  --start-ref <commit>
                Override the inferred original start commit for --manual-rerun.

Project = $PWD (the target repo you cd into before running).
Exit codes: 0 = review passed, 1 = max iterations hit without passing,
            2 = usage / IO / preflight error.
EOF
  exit 2
}

trim_spaces() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

strip_wrapping_quotes() {
  local value="$1"

  if [[ "$value" =~ ^\"(.*)\"$ ]]; then
    value="${BASH_REMATCH[1]}"
  elif [[ "$value" =~ ^\'(.*)\'$ ]]; then
    value="${BASH_REMATCH[1]}"
  fi

  printf '%s' "$value"
}

read_env_value() {
  local name="$1"
  local file="$2"
  local line value stripped q after inner

  [[ -f "$file" ]] || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    line="$(trim_spaces "$line")"
    [[ -z "$line" || "${line:0:1}" == "#" ]] && continue

    if [[ "$line" == export[[:space:]]* ]]; then
      line="$(trim_spaces "${line#export}")"
    fi

    [[ "$line" == "$name="* ]] || continue

    # Keep the raw RHS so we can tell whether a `#` is preceded by
    # whitespace (an inline comment) or sits flush against the value
    # (a literal `#`, e.g. a URL fragment). Use the trimmed copy only
    # to dispatch on the first non-whitespace character.
    value="${line#*=}"
    stripped="$(trim_spaces "$value")"

    case "${stripped:0:1}" in
      '"'|"'")
        # Quoted value: take everything up to the matching closing quote.
        # Anything after (including #) is treated as a trailing comment.
        value="$stripped"
        q="${value:0:1}"
        after="${value:1}"
        inner="${after%%"$q"*}"
        [[ "$inner" != "$after" ]] && value="$q$inner$q"
        ;;
      *)
        # Unquoted: strip the first whitespace-`#` sequence and everything
        # after it. Operating on the raw RHS preserves the distinction
        # between `KEY= # comment` (empty value) and `KEY=#literal`
        # (literal `#`), and works when the value itself contains `#`
        # (e.g. `URL=http://x.example/#frag # comment`).
        if [[ "$value" == *[[:space:]]\#* ]]; then
          value="${value%%[[:space:]]\#*}"
        fi
        value="$(trim_spaces "$value")"
        ;;
    esac

    value="$(strip_wrapping_quotes "$value")"

    printf '%s\n' "$value"
    return 0
  done < "$file"

  return 1
}

read_config_value() {
  local name="$1"
  local default_value="$2"
  local value="${!name-}"
  local dotenv_value

  if [[ -z "$value" ]]; then
    if dotenv_value="$(read_env_value "$name" "$CONFIG_FILE")"; then
      value="$dotenv_value"
    fi
  fi

  printf '%s' "${value:-$default_value}"
}

validate_agent() {
  local name="$1"
  local value="$2"

  case "$value" in
    claude|codex) ;;
    *)
      echo "error: $name must be one of: claude, codex (got: $value)" >&2
      exit 2
      ;;
  esac
}

agent_bin() {
  local agent="$1"

  case "$agent" in
    claude) printf '%s' "$CLAUDE_BIN" ;;
    codex) printf '%s' "$CODEX_BIN" ;;
  esac
}

check_agent_bin() {
  local stage="$1"
  local agent="$2"
  local bin

  bin="$(agent_bin "$agent")"
  command -v "$bin" >/dev/null 2>&1 \
    || { echo "error: ${stage} agent '$agent' requires '$bin' but it is not executable/on PATH" >&2; exit 2; }
}

codex_config_model() {
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local config_file="$codex_home/config.toml"
  local line value

  [[ -r "$config_file" ]] || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="$(trim_spaces "$line")"
    [[ -z "$line" ]] && continue
    [[ "${line:0:1}" == "[" ]] && break
    [[ "$line" =~ ^model[[:space:]]*= ]] || continue

    value="${line#*=}"
    value="$(trim_spaces "$value")"
    value="$(strip_wrapping_quotes "$value")"
    [[ -n "$value" ]] || return 1

    printf '%s' "$value"
    return 0
  done < "$config_file"

  return 1
}

run_development_agent() {
  local agent="$1"
  local prompt="$2"
  local development_file="$3"
  local log_file="$4"
  local bin
  local -a args

  bin="$(agent_bin "$agent")"
  : >"$development_file"

  case "$agent" in
    claude)
      if command -v jq >/dev/null 2>&1; then
        printf '%s' "$prompt" | "$bin" -p --dangerously-skip-permissions \
          --output-format stream-json --include-partial-messages --verbose \
          >"$log_file" 2>&1
        jq -Rsr '[split("\n")[] | fromjson? | select(.type == "result" and (.result? != null)) | .result] | last // ""' \
          "$log_file" >"$development_file" 2>/dev/null || true
      else
        printf '%s' "$prompt" | "$bin" -p --dangerously-skip-permissions >"$development_file" 2>"$log_file"
        {
          printf '\n--- final development message ---\n'
          cat "$development_file"
        } >>"$log_file"
      fi
      ;;
    codex)
      args=(exec -s workspace-write --json --output-last-message "$development_file")
      [[ -n "$CODEX_MODEL" ]] && args+=(-m "$CODEX_MODEL")
      args+=("$prompt")
      "$bin" "${args[@]}" </dev/null >"$log_file" 2>&1
      ;;
  esac
}

run_review_agent() {
  local agent="$1"
  local prompt="$2"
  local review_file="$3"
  local review_log_file="$4"
  local bin
  local -a args

  bin="$(agent_bin "$agent")"
  : >"$review_file"

  case "$agent" in
    claude)
      if command -v jq >/dev/null 2>&1; then
        printf '%s' "$prompt" | "$bin" -p --dangerously-skip-permissions \
          --output-format stream-json --include-partial-messages --verbose \
          >"$review_log_file" 2>&1 || true
        jq -Rsr '[split("\n")[] | fromjson? | select(.type == "result" and (.result? != null)) | .result] | last // ""' \
          "$review_log_file" >"$review_file" 2>/dev/null || true
      else
        printf '%s' "$prompt" | "$bin" -p --dangerously-skip-permissions >"$review_file" 2>"$review_log_file" || true
        {
          printf '\n--- final review message ---\n'
          cat "$review_file"
        } >>"$review_log_file"
      fi
      ;;
    codex)
      args=(exec -s read-only --json --output-last-message "$review_file")
      [[ -n "$CODEX_MODEL" ]] && args+=(-m "$CODEX_MODEL")
      args+=("$prompt")
      "$bin" "${args[@]}" </dev/null >"$review_log_file" 2>&1 || true
      ;;
  esac
}

record_phase() {
  local stage="$1"
  local iteration="$2"
  local agent="$3"
  local log_file="$4"
  local duration_seconds="$5"

  printf '%s\t%s\t%s\t%s\t%s\n' "$stage" "$iteration" "$agent" "$log_file" "$duration_seconds" >>"$PHASES_TSV"
}

phase_duration_seconds() {
  local stage="$1"
  local iteration="$2"

  awk -F '\t' -v stage="$stage" -v iteration="$iteration" '
    NR > 1 && $1 == stage && $2 == iteration { value = $5; found = 1 }
    END { if (found) print value; else print "" }
  ' "$PHASES_TSV"
}

phase_completed() {
  local stage="$1"
  local iteration="$2"

  [[ -f "$PHASES_TSV" ]] || return 1
  awk -F '\t' -v stage="$stage" -v iteration="$iteration" '
    NR > 1 && $1 == stage && $2 == iteration { found = 1 }
    END { exit(found ? 0 : 1) }
  ' "$PHASES_TSV"
}

review_file_passed() {
  local iteration="$1"
  local review_file="$ARTIFACTS/review-${iteration}.md"

  [[ -f "$review_file" ]] || return 1
  tail -n 3 "$review_file" | grep -q '^REVIEW_PASSED$'
}

expand_tilde_path() {
  local path="$1"

  case "$path" in
    "~") printf '%s' "$HOME" ;;
    "~/"*) printf '%s/%s' "$HOME" "${path#'~/'}" ;;
    *) printf '%s' "$path" ;;
  esac
}

write_run_metadata() {
  local file="$1"

  {
    printf 'START_REF=%s\n' "$START_REF"
    printf 'TASK_FILE=%s\n' "$TASK_FILE"
    printf 'START_STAGE=%s\n' "$ORIGINAL_START_STAGE"
    printf 'MAX=%s\n' "$MAX"
    printf 'DEV_AGENT=%s\n' "$DEV_AGENT"
    printf 'REVIEW_AGENT=%s\n' "$REVIEW_AGENT"
    printf 'CODEX_MODEL=%s\n' "$CODEX_MODEL"
  } >"$file"
}

infer_original_start_stage() {
  local artifacts="$1"
  local metadata_file="$artifacts/run.env"
  local value

  if value="$(read_env_value "START_STAGE" "$metadata_file" 2>/dev/null)"; then
    value="$(trim_spaces "${value,,}")"
    case "$value" in
      development|review)
        printf '%s' "$value"
        return 0
        ;;
    esac
  fi

  if phase_completed "development" 0 || [[ -e "$artifacts/development-0.log" ]]; then
    printf 'development'
  else
    printf 'review'
  fi
}

infer_start_ref_from_run() {
  local artifacts="$1"
  local metadata_file="$artifacts/run.env"
  local summary_file="$artifacts/summary.md"
  local value
  local -a logs

  if [[ -n "$START_REF_OVERRIDE" ]]; then
    printf '%s' "$START_REF_OVERRIDE"
    return 0
  fi

  if value="$(read_env_value "START_REF" "$metadata_file" 2>/dev/null)" && [[ -n "$value" ]]; then
    printf '%s' "$value"
    return 0
  fi

  if [[ -f "$summary_file" ]]; then
    value="$(awk -F ': ' '$1 == "- Start ref" { print $2; exit }' "$summary_file")"
    if [[ -n "$value" ]]; then
      printf '%s' "$value"
      return 0
    fi
  fi

  shopt -s nullglob
  logs=("$artifacts"/review-*.log)
  shopt -u nullglob
  if (( ${#logs[@]} > 0 )); then
    value="$(grep -Eho 'git diff [0-9a-f]{7,40}' "${logs[@]}" 2>/dev/null | awk '{ print $3; exit }' || true)"
    if [[ -n "$value" ]]; then
      printf '%s' "$value"
      return 0
    fi
  fi

  return 1
}

parse_rerun_from() {
  local value="$1"

  if [[ "$value" =~ ^(development|review)-([0-9]+)$ ]]; then
    RERUN_STAGE="${BASH_REMATCH[1]}"
    RERUN_ITERATION="$((10#${BASH_REMATCH[2]}))"
    return 0
  fi

  echo "error: --rerun-from must look like development-N or review-N (got: $value)" >&2
  exit 2
}

infer_rerun_start_from_phases() {
  local iteration=0

  while (( iteration < MAX )); do
    if ! [[ "$ORIGINAL_START_STAGE" == "review" && "$iteration" -eq 0 ]]; then
      if ! phase_completed "development" "$iteration"; then
        printf 'development %s\n' "$iteration"
        return 0
      fi
    fi

    if ! phase_completed "review" "$iteration"; then
      printf 'review %s\n' "$iteration"
      return 0
    fi

    if review_file_passed "$iteration"; then
      printf 'done %s\n' "$((iteration + 1))"
      return 0
    fi

    iteration=$((iteration + 1))
  done

  printf 'done %s\n' "$MAX"
}

fmt_count() {
  local value="${1:-}"

  if [[ -z "$value" ]]; then
    printf 'n/a'
    return 0
  fi

  awk -v n="$value" '
    function comma(value, text, out) {
      text = sprintf("%.0f", value)
      while (length(text) > 3) {
        out = "," substr(text, length(text) - 2) out
        text = substr(text, 1, length(text) - 3)
      }
      return text out
    }
    BEGIN { printf "%s", comma(n + 0) }
  '
}

fmt_cost() {
  local value="${1:-}"
  local source="${2:-unavailable}"

  if [[ -z "$value" ]]; then
    printf 'n/a'
    return 0
  fi

  awk -v value="$value" -v source="$source" '
    BEGIN {
      prefix = (source == "reported") ? "" : "≈ "
      printf "%s$%.2f", prefix, value + 0
    }
  '
}

fmt_models() {
  local value="${1:-}"

  if [[ -z "$value" ]]; then
    printf 'n/a'
  else
    printf '%s' "${value//,/, }"
  fi
}

add_decimal() {
  local left="${1:-0}"
  local right="${2:-0}"

  awk -v left="$left" -v right="$right" 'BEGIN { printf "%.10f", left + right }'
}

extract_iteration() {
  local log_file="$1"
  local prefix="$2"
  local base

  base="$(basename "$log_file")"
  base="${base#"$prefix"-}"
  printf '%s' "${base%.log}"
}

claude_log_metrics() {
  local log_file="$1"

  if ! command -v jq >/dev/null 2>&1; then
    printf '|missing-jq|||||||missing-jq\n'
    return 0
  fi

  jq -Rsr '
    def num($value):
      ($value // 0) | if type == "number" then . else (tonumber? // 0) end;

    def claude_rates($model):
      ($model | ascii_downcase) as $m
      | if $m == "unknown" then null
        elif ($m | test("opus.*4([._-]?[567]|\\.[567])")) then
          {input: 5, cache_write_5m: 6.25, cache_write_1h: 10, cache_read: 0.50, output: 25}
        elif ($m | test("opus.*4")) then
          {input: 15, cache_write_5m: 18.75, cache_write_1h: 30, cache_read: 1.50, output: 75}
        elif ($m | test("sonnet")) then
          {input: 3, cache_write_5m: 3.75, cache_write_1h: 6, cache_read: 0.30, output: 15}
        elif ($m | test("haiku.*3([._-]?5|\\.5)")) then
          {input: 0.80, cache_write_5m: 1, cache_write_1h: 1.60, cache_read: 0.08, output: 4}
        elif ($m | test("haiku")) then
          {input: 1, cache_write_5m: 1.25, cache_write_1h: 2, cache_read: 0.10, output: 5}
        else null
        end;

    def model_name($event):
      [
        $event.message.model?,
        $event.event.message.model?,
        $event.model?,
        $event.response.model?
      ] | map(select(. != null and . != "")) | first // "unknown";

    def usage_record($usage):
      {
        input: num($usage.input_tokens // $usage.prompt_tokens),
        cache_write_5m: (
          if $usage.cache_creation_input_tokens? != null then
            num($usage.cache_creation_input_tokens)
          else
            num($usage.cache_creation.ephemeral_5m_input_tokens // $usage.ephemeral_5m_input_tokens)
          end
        ),
        cache_write_1h: (
          if $usage.cache_creation_input_tokens? != null then
            0
          else
            num($usage.cache_creation.ephemeral_1h_input_tokens // $usage.ephemeral_1h_input_tokens)
          end
        ),
        cache_read: num($usage.cache_read_input_tokens // $usage.cached_input_tokens // $usage.cache_read_tokens),
        output: num($usage.output_tokens // $usage.completion_tokens)
      };

    def cost_for_model($model):
      (claude_rates($model.model)) as $rates
      | if $rates == null then null
        else (
          (
            ($model.input * $rates.input) +
            ($model.cache_write_5m * $rates.cache_write_5m) +
            ($model.cache_write_1h * $rates.cache_write_1h) +
            ($model.cache_read * $rates.cache_read) +
            ($model.output * $rates.output)
          ) / 1000000
        )
        end;

    [split("\n")[] | fromjson?] as $events
    | [
        range(0; $events | length) as $index
        | $events[$index] as $event
        | select($event.type? == "assistant" and ($event.message.usage? != null))
        | {
            index: $index,
            id: ($event.message.id // $event.request_id // ($index | tostring)),
            model: model_name($event),
            usage: usage_record($event.message.usage)
          }
      ] as $assistant_usages
    | [
        $assistant_usages
        | group_by(.id)
        | .[]
        | max_by(.index)
      ] as $assistant_records
    | [
        range(0; $events | length) as $index
        | $events[$index] as $event
        | select($event.type? == "result" and ($event.usage? != null))
        | {
            index: $index,
            id: ($event.session_id // ($index | tostring)),
            model: model_name($event),
            usage: usage_record($event.usage)
          }
      ] as $result_records
    | (if ($assistant_records | length) > 0 then $assistant_records else $result_records end) as $records
    | [
        $records[]
        | {
            model,
            input: .usage.input,
            cache_write_5m: .usage.cache_write_5m,
            cache_write_1h: .usage.cache_write_1h,
            cache_read: .usage.cache_read,
            output: .usage.output
          }
      ]
      | group_by(.model)
      | map({
          model: .[0].model,
          input: (map(.input) | add // 0),
          cache_write_5m: (map(.cache_write_5m) | add // 0),
          cache_write_1h: (map(.cache_write_1h) | add // 0),
          cache_read: (map(.cache_read) | add // 0),
          output: (map(.output) | add // 0)
        }) as $models
    | (reduce $models[] as $model (
        {input: 0, cache_write: 0, cache_read: 0, output: 0};
        .input += $model.input
        | .cache_write += ($model.cache_write_5m + $model.cache_write_1h)
        | .cache_read += $model.cache_read
        | .output += $model.output
      )) as $totals
    | ([ $events[] | select(.type? == "result") | .total_cost_usd? | tonumber? ] | last) as $reported_cost
    | ([ $models[] | cost_for_model(.) ] | map(select(. != null))) as $estimated_costs
    | (if ($models | length) > 0 and ($estimated_costs | length) == ($models | length) then ($estimated_costs | add // 0) else null end) as $estimated_cost
    | (if $reported_cost != null then $reported_cost elif $estimated_cost != null then $estimated_cost else null end) as $cost
    | (if $reported_cost != null then "reported" elif $estimated_cost != null then "estimated" elif ($records | length) == 0 then "no-usage" else "unknown-price" end) as $source
    | (([ $events[] | select(.type? == "result") | .num_turns? | numbers ] | last) // ($records | length)) as $turns
    | [
        ($cost // ""),
        $source,
        ($turns // ""),
        $totals.input,
        $totals.cache_write,
        $totals.cache_read,
        $totals.output,
        ($models | map(.model) | unique | join(",")),
        $source
      ] | map(tostring) | join("|")
  ' "$log_file" 2>/dev/null || printf '|parse-error|||||||parse-error\n'
}

codex_log_metrics() {
  local log_file="$1"
  local fallback_model="${2:-}"

  if ! command -v jq >/dev/null 2>&1; then
    printf '|missing-jq|||||||missing-jq\n'
    return 0
  fi

  jq -Rsr --arg fallback_model "$fallback_model" '
    def num($value):
      ($value // 0) | if type == "number" then . else (tonumber? // 0) end;

    def known_model($value):
      $value | select(type == "string" and . != "" and . != "unknown");

    def openai_rates($model):
      ($model | ascii_downcase) as $m
      | if ($m | startswith("gpt-5.5-pro")) then
          {input: 30, cached: null, output: 180}
        elif ($m | startswith("gpt-5.5")) then
          {input: 5, cached: 0.50, output: 30}
        elif ($m | startswith("gpt-5.4-pro")) then
          {input: 30, cached: null, output: 180}
        elif ($m | startswith("gpt-5.4-mini")) then
          {input: 0.75, cached: 0.075, output: 4.50}
        elif ($m | startswith("gpt-5.4-nano")) then
          {input: 0.20, cached: 0.02, output: 1.25}
        elif ($m | startswith("gpt-5.4")) then
          {input: 2.50, cached: 0.25, output: 15}
        elif ($m | startswith("gpt-5.3-codex")) then
          {input: 1.75, cached: 0.175, output: 14}
        elif ($m | startswith("gpt-5.3")) then
          {input: 1.75, cached: 0.175, output: 14}
        elif ($m | startswith("gpt-5.2")) then
          {input: 1.75, cached: 0.175, output: 14}
        elif ($m | startswith("gpt-5.1-codex-mini")) then
          {input: 0.25, cached: 0.025, output: 2}
        elif ($m | startswith("gpt-5.1-codex")) then
          {input: 1.25, cached: 0.125, output: 10}
        elif ($m | startswith("gpt-5.1")) then
          {input: 1.25, cached: 0.125, output: 10}
        elif ($m | startswith("gpt-5-mini")) then
          {input: 0.25, cached: 0.025, output: 2}
        elif ($m | startswith("gpt-5-nano")) then
          {input: 0.05, cached: 0.005, output: 0.40}
        elif ($m | startswith("gpt-5-codex")) then
          {input: 1.25, cached: 0.125, output: 10}
        elif ($m | startswith("gpt-5")) then
          {input: 1.25, cached: 0.125, output: 10}
        elif ($m | startswith("codex-mini-latest")) then
          {input: 1.50, cached: 0.375, output: 6}
        else null
        end;

    def model_name($event; $usage):
      [
        $event.model?,
        $event.response.model?,
        $event.item.model?,
        $event.event.model?,
        $event.payload.model?,
        $event.payload.settings.model?,
        $event.payload.collaboration_mode.settings.model?,
        $event.info.model?,
        $event.payload.info.model?,
        $usage.model?
      ] | map(known_model(.)) | first // "unknown";

    def usage_object($event):
      $event.usage?
      // $event.token_usage?
      // $event.total_token_usage?
      // $event.info.total_token_usage?
      // $event.info.usage?
      // $event.payload.usage?
      // $event.payload.token_usage?
      // $event.payload.total_token_usage?
      // $event.payload.info.total_token_usage?
      // $event.payload.info.usage?
      // empty;

    def usage_record($usage):
      {
        input: num($usage.input_tokens // $usage.prompt_tokens // $usage.total_input_tokens),
        cached: num(
          $usage.cached_input_tokens
          // $usage.cached_tokens
          // $usage.input_tokens_details.cached_tokens
          // $usage.prompt_tokens_details.cached_tokens
        ),
        output: num($usage.output_tokens // $usage.completion_tokens // $usage.total_output_tokens)
      };

    [split("\n")[] | fromjson?] as $events
    | [
        range(0; $events | length) as $index
        | $events[$index] as $event
        | usage_object($event) as $usage
        | {
            index: $index,
            model: model_name($event; $usage),
            usage: usage_record($usage)
          }
        | select((.usage.input + .usage.cached + .usage.output) > 0)
      ] as $usage_events
    | ($usage_events | last) as $last_usage
    | (
        known_model($last_usage.model)
        // ([ $events[] | .. | objects | known_model(.model?) ] | last)
        // known_model($fallback_model)
        // "unknown"
      ) as $model
    | (($last_usage.usage // {input: 0, cached: 0, output: 0})) as $usage
    | (openai_rates($model)) as $rates
    | ([ $events[] | .. | objects | .total_cost_usd? | tonumber? ] | last) as $reported_cost
    | (
        if $rates != null and ($rates.cached != null or $usage.cached == 0) and (($usage.input + $usage.output) > 0) then
          ((([$usage.input - $usage.cached, 0] | max) * $rates.input) + ($usage.cached * ($rates.cached // $rates.input)) + ($usage.output * $rates.output)) / 1000000
        else null
        end
      ) as $estimated_cost
    | (if $reported_cost != null then $reported_cost elif $estimated_cost != null then $estimated_cost else null end) as $cost
    | (if $reported_cost != null then "reported" elif $estimated_cost != null then "estimated" elif ($usage_events | length) == 0 then "no-usage" else "unknown-price" end) as $source
    | (([ $events[] | .. | objects | .num_turns? | numbers ] | last)
       // ([ $events[] | .type? | tostring | select(test("turn[_ -]?complete|turncomplete"; "i")) ] | length)
       // "") as $turns
    | [
        ($cost // ""),
        $source,
        $turns,
        $usage.input,
        "",
        $usage.cached,
        $usage.output,
        $model,
        $source
      ] | map(tostring) | join("|")
  ' "$log_file" 2>/dev/null || printf '|parse-error|||||||parse-error\n'
}

agent_log_metrics() {
  local agent="$1"
  local log_file="$2"

  case "$agent" in
    claude) claude_log_metrics "$log_file" ;;
    codex) codex_log_metrics "$log_file" "${CODEX_METRICS_MODEL:-}" ;;
    *) printf '|unsupported-agent|||||||unsupported-agent\n' ;;
  esac
}

append_stage_usage_summary() {
  local summary_file="$1"
  local artifacts="$2"
  local stage="$3"
  local agent="$4"
  local prefix="$5"
  local title="$6"
  local -a logs sorted_logs
  local log_file base iteration duration metrics
  local cost cost_source turns input cache_write cache_read output models status
  local row_count=0
  local cost_count=0
  local usage_count=0
  local total_cost=0
  local total_duration=0
  local total_turns=0
  local total_input=0
  local total_cache_write=0
  local total_cache_read=0
  local total_output=0
  local notes=""

  sorted_logs=()

  shopt -s nullglob
  logs=("$artifacts"/"$prefix"-*.log)
  shopt -u nullglob

  if (( ${#logs[@]} > 0 )); then
    while IFS= read -r log_file; do
      sorted_logs+=("$log_file")
    done < <(printf '%s\n' "${logs[@]}" | sort -V)
  fi

  {
    printf '### %s (`%s`)\n\n' "$title" "$agent"

    if (( ${#sorted_logs[@]} == 0 )); then
      printf 'No `%s-*.log` files were found.\n\n' "$prefix"
      return 0
    fi

    if [[ "$agent" == "claude" ]]; then
      printf '| Log | Cost | Duration | Turns | Input | Cache write | Cache read | Output | Models |\n'
      printf '| --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: | --- |\n'
    else
      printf '| Log | Cost | Duration | Turns | Input | Cached input | Output | Models |\n'
      printf '| --- | ---: | ---: | ---: | ---: | ---: | ---: | --- |\n'
    fi
  } >>"$summary_file"

  for log_file in "${sorted_logs[@]}"; do
    row_count=$((row_count + 1))
    base="$(basename "$log_file")"
    iteration="$(extract_iteration "$log_file" "$prefix")"
    duration="$(phase_duration_seconds "$stage" "$iteration")"
    metrics="$(agent_log_metrics "$agent" "$log_file")"

    IFS='|' read -r cost cost_source turns input cache_write cache_read output models status <<<"$metrics"

    if [[ "$status" == "no-usage" || "$status" == "missing-jq" || "$status" == "parse-error" ]]; then
      turns=""
      input=""
      cache_write=""
      cache_read=""
      output=""
      models=""
    fi

    [[ -n "$duration" ]] && total_duration=$((total_duration + duration))
    [[ -n "$turns" ]] && total_turns=$((total_turns + turns))
    [[ -n "$input" ]] && total_input=$((total_input + input))
    [[ -n "$cache_write" ]] && total_cache_write=$((total_cache_write + cache_write))
    [[ -n "$cache_read" ]] && total_cache_read=$((total_cache_read + cache_read))
    [[ -n "$output" ]] && total_output=$((total_output + output))

    if [[ -n "$cost" ]]; then
      cost_count=$((cost_count + 1))
      total_cost="$(add_decimal "$total_cost" "$cost")"
    fi

    if [[ -n "$turns$input$cache_write$cache_read$output" ]]; then
      usage_count=$((usage_count + 1))
    fi

    case "$status" in
      missing-jq) notes="${notes} jq" ;;
      no-usage) notes="${notes} no-usage" ;;
      unknown-price) notes="${notes} unknown-price" ;;
      parse-error) notes="${notes} parse-error" ;;
    esac

    if [[ "$agent" == "claude" ]]; then
      printf '| `%s` | %s | %s | %s | %s | %s | %s | %s | %s |\n' \
        "${base%.log}" \
        "$(fmt_cost "$cost" "$cost_source")" \
        "$(fmt_elapsed "${duration:-0}")" \
        "$(fmt_count "$turns")" \
        "$(fmt_count "$input")" \
        "$(fmt_count "$cache_write")" \
        "$(fmt_count "$cache_read")" \
        "$(fmt_count "$output")" \
        "$(fmt_models "$models")" >>"$summary_file"
    else
      printf '| `%s` | %s | %s | %s | %s | %s | %s | %s |\n' \
        "${base%.log}" \
        "$(fmt_cost "$cost" "$cost_source")" \
        "$(fmt_elapsed "${duration:-0}")" \
        "$(fmt_count "$turns")" \
        "$(fmt_count "$input")" \
        "$(fmt_count "$cache_read")" \
        "$(fmt_count "$output")" \
        "$(fmt_models "$models")" >>"$summary_file"
    fi
  done

  {
    if [[ "$agent" == "claude" ]]; then
      printf '| **Total** | %s | %s | %s | %s | %s | %s | %s |  |\n' \
        "$(if (( cost_count > 0 )); then fmt_cost "$total_cost" estimated; else printf 'n/a'; fi)" \
        "$(fmt_elapsed "$total_duration")" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_turns"; else printf 'n/a'; fi)" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_input"; else printf 'n/a'; fi)" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_cache_write"; else printf 'n/a'; fi)" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_cache_read"; else printf 'n/a'; fi)" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_output"; else printf 'n/a'; fi)"
    else
      printf '| **Total** | %s | %s | %s | %s | %s | %s |  |\n' \
        "$(if (( cost_count > 0 )); then fmt_cost "$total_cost" estimated; else printf 'n/a'; fi)" \
        "$(fmt_elapsed "$total_duration")" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_turns"; else printf 'n/a'; fi)" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_input"; else printf 'n/a'; fi)" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_cache_read"; else printf 'n/a'; fi)" \
        "$(if (( usage_count > 0 )); then fmt_count "$total_output"; else printf 'n/a'; fi)"
    fi

    if [[ "$notes" == *"jq"* ]]; then
      printf '\nUsage metadata was not parsed because `jq` is not available.\n'
    elif [[ "$notes" == *"parse-error"* ]]; then
      printf '\nSome usage metadata could not be parsed from the JSONL logs.\n'
    elif [[ "$notes" == *"no-usage"* ]]; then
      printf '\nSome logs did not expose usage metadata, so their token and cost fields are `n/a`.\n'
    elif [[ "$notes" == *"unknown-price"* ]]; then
      printf '\nSome costs are `n/a` because the log model has no built-in API rate.\n'
    fi

    printf '\n'
  } >>"$summary_file"
}

append_usage_summary() {
  local summary_file="$1"
  local artifacts="$2"

  {
    printf '\n## Usage and Cost Estimates\n\n'
    printf 'Generated after the verdict from `%s`, `%s`, and `%s`. Costs use JSON usage metadata when available. Reported CLI costs are preferred; otherwise known first-party API token rates are applied as best-effort estimates. Subscription plans, third-party providers, regional pricing, long-context modes, priority processing, and separate tool fees can differ.\n\n' \
      "$(basename "$PHASES_TSV")" 'development-*.log' 'review-*.log'
  } >>"$summary_file"

  append_stage_usage_summary "$summary_file" "$artifacts" "development" "$DEV_AGENT" "development" "Development Agent Usage"
  append_stage_usage_summary "$summary_file" "$artifacts" "review" "$REVIEW_AGENT" "review" "Review Agent Usage"
}

log_phase() { printf '[loop %s] %s\n' "$(date +%H:%M:%S)" "$*"; }

fmt_elapsed() {
  local s=$1
  if (( s >= 60 )); then printf '%dm%02ds' "$((s/60))" "$((s%60))"
  else printf '%ds' "$s"
  fi
}

cleanup_old_runs() {
  local root="$1"
  local keep="$2"
  local current_run="$3"
  local count=0
  local dir
  local -a run_dirs sorted_run_dirs

  shopt -s nullglob
  run_dirs=("$root"/run-*)
  shopt -u nullglob

  (( ${#run_dirs[@]} == 0 )) && return 0
  while IFS= read -r dir; do
    sorted_run_dirs+=("$dir")
  done < <(printf '%s\n' "${run_dirs[@]}" | sort -r)

  for dir in "${sorted_run_dirs[@]}"; do
    [[ -d "$dir" && ! -L "$dir" ]] || continue
    count=$((count + 1))
    if (( count > keep )) && [[ "$dir" != "$current_run" ]]; then
      rm -rf -- "$dir"
    fi
  done

  return 0
}

# Allow the test suite to load helpers without running the loop.
(return 0 2>/dev/null) && return 0

TASK_FILE=""
MAX=10
START_STAGE="development"
MANUAL_RERUN=""
RERUN_FROM=""
RERUN_STAGE=""
RERUN_ITERATION=""
START_REF_OVERRIDE=""

while (( $# > 0 )); do
  case "$1" in
    --max)
      [[ $# -ge 2 ]] || { echo "error: --max requires a value" >&2; usage; }
      MAX="$2"; shift 2 ;;
    --max=*)
      MAX="${1#--max=}"; shift ;;
    --start-stage)
      [[ $# -ge 2 ]] || { echo "error: --start-stage requires a value" >&2; usage; }
      START_STAGE="$2"; shift 2 ;;
    --start-stage=*)
      START_STAGE="${1#--start-stage=}"; shift ;;
    --start-review|--review-first)
      START_STAGE="review"; shift ;;
    --manual-rerun|--resume-run|--rerun-run)
      [[ $# -ge 2 ]] || { echo "error: $1 requires a run directory" >&2; usage; }
      MANUAL_RERUN="$2"; shift 2 ;;
    --manual-rerun=*|--resume-run=*|--rerun-run=*)
      MANUAL_RERUN="${1#*=}"; shift ;;
    --rerun-from)
      [[ $# -ge 2 ]] || { echo "error: --rerun-from requires a value" >&2; usage; }
      RERUN_FROM="$2"; shift 2 ;;
    --rerun-from=*)
      RERUN_FROM="${1#--rerun-from=}"; shift ;;
    --start-ref)
      [[ $# -ge 2 ]] || { echo "error: --start-ref requires a commit" >&2; usage; }
      START_REF_OVERRIDE="$2"; shift 2 ;;
    --start-ref=*)
      START_REF_OVERRIDE="${1#--start-ref=}"; shift ;;
    -h|--help)
      usage ;;
    --)
      shift; break ;;
    -*)
      echo "error: unknown flag: $1" >&2; usage ;;
    *)
      if [[ -z "$TASK_FILE" ]]; then
        TASK_FILE="$1"; shift
      else
        echo "error: unexpected positional argument: $1" >&2; usage
      fi ;;
  esac
done

if [[ -n "$RERUN_FROM" ]]; then
  parse_rerun_from "$RERUN_FROM"
fi

if [[ -n "$START_REF_OVERRIDE" ]]; then
  # Restrict to characters git permits in commits, refs, and short SHAs; the
  # value is later passed to git rev-parse and embedded in the review prompt.
  [[ "$START_REF_OVERRIDE" =~ ^[A-Za-z0-9._/@^~+=-]+$ ]] \
    || { echo "error: --start-ref contains unsupported characters: $START_REF_OVERRIDE" >&2; exit 2; }
fi

if [[ -z "$MANUAL_RERUN" ]]; then
  [[ -z "$RERUN_FROM" ]] || { echo "error: --rerun-from requires --manual-rerun" >&2; exit 2; }
  [[ -z "$START_REF_OVERRIDE" ]] || { echo "error: --start-ref is only valid with --manual-rerun" >&2; exit 2; }
  [[ -n "$TASK_FILE" ]] || { echo "error: <task-file> required" >&2; usage; }
fi

[[ "$MAX" =~ ^[1-9][0-9]*$ ]] || { echo "error: --max must be a positive integer (got: $MAX)" >&2; exit 2; }
START_STAGE="$(trim_spaces "${START_STAGE,,}")"
case "$START_STAGE" in
  development|review) ;;
  *) echo "error: --start-stage must be one of: development, review (got: $START_STAGE)" >&2; exit 2 ;;
esac

if [[ -n "$TASK_FILE" ]]; then
  [[ -r "$TASK_FILE" ]] || { echo "error: task file not readable: $TASK_FILE" >&2; exit 2; }
fi
git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
  || { echo "error: \$PWD is not inside a git work tree (the diff-based review depends on it)" >&2; exit 2; }

DEFAULT_KEEP_RUNS=3
DEFAULT_DEV_AGENT="claude"
DEFAULT_REVIEW_AGENT="codex"
CONFIG_FILE=".env"

DEV_AGENT="$(read_config_value "DEV_AGENT" "$DEFAULT_DEV_AGENT")"
REVIEW_AGENT="$(read_config_value "REVIEW_AGENT" "$DEFAULT_REVIEW_AGENT")"
CODEX_BIN="$(read_config_value "CODEX_BIN" "codex")"
CODEX_MODEL="$(read_config_value "CODEX_MODEL" "")"
CLAUDE_BIN="$(read_config_value "CLAUDE_BIN" "claude")"
KEEP_RUNS="$(read_config_value "DEVELOP_REVIEW_LOOP_KEEP_RUNS" "$DEFAULT_KEEP_RUNS")"

DEV_AGENT="$(trim_spaces "${DEV_AGENT,,}")"
REVIEW_AGENT="$(trim_spaces "${REVIEW_AGENT,,}")"
CODEX_BIN="$(trim_spaces "$CODEX_BIN")"
CODEX_MODEL="$(trim_spaces "$CODEX_MODEL")"
CLAUDE_BIN="$(trim_spaces "$CLAUDE_BIN")"
KEEP_RUNS="$(trim_spaces "$KEEP_RUNS")"
CODEX_METRICS_MODEL="$CODEX_MODEL"
if [[ -z "$CODEX_METRICS_MODEL" ]]; then
  CODEX_METRICS_MODEL="$(codex_config_model || true)"
fi

validate_agent "DEV_AGENT" "$DEV_AGENT"
validate_agent "REVIEW_AGENT" "$REVIEW_AGENT"
check_agent_bin "development" "$DEV_AGENT"
check_agent_bin "review" "$REVIEW_AGENT"
[[ "$KEEP_RUNS" =~ ^[1-9][0-9]*$ ]] \
  || { echo "error: DEVELOP_REVIEW_LOOP_KEEP_RUNS must be a positive integer (got: $KEEP_RUNS)" >&2; exit 2; }

ORIGINAL_START_STAGE="$START_STAGE"
LOOP_START_STAGE="$START_STAGE"
START_REVIEW_NUM=0
MANUAL_RERUN_ENABLED=false
TASK_CONTENT=""
TASK_CONTENT_AVAILABLE=false

ARTIFACTS_ROOT=".develop-review-loop"
if [[ -n "$MANUAL_RERUN" ]]; then
  MANUAL_RERUN_ENABLED=true
  ARTIFACTS="$(expand_tilde_path "$MANUAL_RERUN")"
  [[ -d "$ARTIFACTS" ]] || { echo "error: --manual-rerun directory not found: $ARTIFACTS" >&2; exit 2; }
  ARTIFACTS_ROOT="$(dirname "$ARTIFACTS")"
  RUN_ID="$(basename "$ARTIFACTS")"
  PHASES_TSV="$ARTIFACTS/phases.tsv"
  if [[ ! -f "$PHASES_TSV" ]]; then
    printf 'stage\titeration\tagent\tlog\tduration_seconds\n' >"$PHASES_TSV"
  fi
  ORIGINAL_START_STAGE="$(infer_original_start_stage "$ARTIFACTS")"
else
  RUN_ID="run-$(date +%Y%m%d-%H%M%S)-$$"
  ARTIFACTS="$ARTIFACTS_ROOT/$RUN_ID"
  PHASES_TSV="$ARTIFACTS/phases.tsv"
  mkdir -p "$ARTIFACTS_ROOT"
  mkdir "$ARTIFACTS"
  printf 'stage\titeration\tagent\tlog\tduration_seconds\n' >"$PHASES_TSV"
fi

ln -sfn "$RUN_ID" "$ARTIFACTS_ROOT/latest" 2>/dev/null || true

if $MANUAL_RERUN_ENABLED; then
  START_REF="$(infer_start_ref_from_run "$ARTIFACTS")" \
    || { echo "error: could not infer original start ref for $ARTIFACTS; pass --start-ref <commit>" >&2; exit 2; }
else
  START_REF="$(git rev-parse HEAD)"
fi
git rev-parse --verify "$START_REF^{commit}" >/dev/null 2>&1 \
  || { echo "error: start ref is not a valid commit in this repo: $START_REF" >&2; exit 2; }

START_TIME="$(date +%s)"
RUN_TASK_FILE="$ARTIFACTS/task.md"
RUN_METADATA="$ARTIFACTS/run.env"

if [[ -n "$TASK_FILE" ]]; then
  TASK_CONTENT="$(cat "$TASK_FILE")"
  TASK_CONTENT_AVAILABLE=true
elif METADATA_TASK_FILE="$(read_env_value "TASK_FILE" "$RUN_METADATA" 2>/dev/null)" && [[ -r "$METADATA_TASK_FILE" ]]; then
  TASK_FILE="$METADATA_TASK_FILE"
  TASK_CONTENT="$(cat "$TASK_FILE")"
  TASK_CONTENT_AVAILABLE=true
elif [[ -f "$RUN_TASK_FILE" ]]; then
  TASK_CONTENT="$(cat "$RUN_TASK_FILE")"
  TASK_CONTENT_AVAILABLE=true
fi

if [[ "$TASK_CONTENT_AVAILABLE" == true && ! -f "$RUN_TASK_FILE" ]]; then
  printf '%s' "$TASK_CONTENT" >"$RUN_TASK_FILE"
fi

if [[ -z "$MANUAL_RERUN" || ! -f "$RUN_METADATA" ]]; then
  write_run_metadata "$RUN_METADATA"
fi

if $MANUAL_RERUN_ENABLED; then
  if [[ -n "$RERUN_STAGE" ]]; then
    LOOP_START_STAGE="$RERUN_STAGE"
    START_REVIEW_NUM="$RERUN_ITERATION"
  else
    read -r LOOP_START_STAGE START_REVIEW_NUM < <(infer_rerun_start_from_phases)
    if [[ "$LOOP_START_STAGE" == "done" ]]; then
      echo "error: $ARTIFACTS appears complete or already at --max $MAX; pass --max larger or --rerun-from development-N|review-N" >&2
      exit 2
    fi
  fi

  if (( START_REVIEW_NUM >= MAX )); then
    echo "error: rerun start ${LOOP_START_STAGE}-${START_REVIEW_NUM} is outside --max $MAX; pass --max greater than $START_REVIEW_NUM" >&2
    exit 2
  fi
fi

if [[ "$LOOP_START_STAGE" == "development" && "$START_REVIEW_NUM" -eq 0 && "$TASK_CONTENT_AVAILABLE" != true ]]; then
  echo "error: rerun from development-0 requires a task file or $RUN_TASK_FILE" >&2
  exit 2
fi

if [[ "$LOOP_START_STAGE" == "development" && "$START_REVIEW_NUM" -gt 0 && ! -f "$ARTIFACTS/review-$((START_REVIEW_NUM - 1)).md" ]]; then
  echo "error: rerun from development-${START_REVIEW_NUM} requires $ARTIFACTS/review-$((START_REVIEW_NUM - 1)).md" >&2
  exit 2
fi

if $MANUAL_RERUN_ENABLED; then
  log_phase "manual rerun: resuming $ARTIFACTS at ${LOOP_START_STAGE}-${START_REVIEW_NUM}"
fi

REVIEW_PROMPT="You are reviewing the cumulative changes in the current git work tree against the recorded start commit.

1. Run 'git diff $START_REF' to see the full delta from the start of this loop (not just the latest fix).
2. Evaluate the changes for correctness, edge cases, style, security, and regressions in unrelated code.
3. Write your review in plain text. Be specific: cite filenames and line ranges where relevant.
4. End your output with EXACTLY ONE of these two tokens on its own final line, with nothing after it:
   - REVIEW_PASSED  (if the changes are acceptable as-is)
   - REVIEW_FAILED  (if any issue should block acceptance)

Do not modify files. Do not commit.
Do not write either token anywhere else in your review. The final line is the only signal."

review_passed=false
review_num="$START_REVIEW_NUM"
final_review_file=""
final_review_log_file=""

while [[ "$review_passed" == false && "$review_num" -lt "$MAX" ]]; do
  development_file="$ARTIFACTS/development-${review_num}.md"
  log_file="$ARTIFACTS/development-${review_num}.log"
  review_file="$ARTIFACTS/review-${review_num}.md"
  review_log_file="$ARTIFACTS/review-${review_num}.log"

  if [[ "$LOOP_START_STAGE" == "review" && "$review_num" -eq "$START_REVIEW_NUM" ]]; then
    log_phase "iter $review_num review-start: skipping development stage; reviewing existing work tree changes"
  else
    if (( review_num == 0 )); then
      phase_label="implement"
      phase_done_label="implement"
      development_prompt="Implement the task below. Make code changes directly in the working tree of the current repo. Do not commit.

Task:

${TASK_CONTENT}"
    else
      prev_review="$ARTIFACTS/review-$((review_num - 1)).md"
      phase_label="fix (from $prev_review)"
      phase_done_label="fix"
      review_content="$(cat "$prev_review")"
      development_prompt="The review stage flagged the issues below. Edit the code to address them. Do not revert unrelated work. Do not commit.

Review:

${review_content}"
    fi

    log_phase "iter $review_num $phase_label: start (tail -f $log_file or run develop-review-loop-watch for live progress)"
    phase_start=$(date +%s)
    run_development_agent "$DEV_AGENT" "$development_prompt" "$development_file" "$log_file"
    if [[ ! -s "$development_file" ]]; then
      cat >"$development_file" <<EOF
Development agent '$DEV_AGENT' did not produce a final development message.
See $log_file for the raw development-stage log.
EOF
    fi
    phase_duration=$(($(date +%s) - phase_start))
    record_phase "development" "$review_num" "$DEV_AGENT" "$log_file" "$phase_duration"
    log_phase "iter $review_num $phase_done_label: done ($(fmt_elapsed "$phase_duration"))"
  fi

  log_phase "iter $review_num review: start (tail -f $review_log_file or run develop-review-loop-watch for live progress)"
  phase_start=$(date +%s)
  run_review_agent "$REVIEW_AGENT" "$REVIEW_PROMPT" "$review_file" "$review_log_file"
  if [[ ! -s "$review_file" ]]; then
    cat >"$review_file" <<EOF
Review agent '$REVIEW_AGENT' did not produce a final review message. See $review_log_file for the raw review-stage log.

REVIEW_FAILED
EOF
  fi
  phase_duration=$(($(date +%s) - phase_start))
  record_phase "review" "$review_num" "$REVIEW_AGENT" "$review_log_file" "$phase_duration"
  log_phase "iter $review_num review: done ($(fmt_elapsed "$phase_duration"))"

  if tail -n 3 "$review_file" | grep -q '^REVIEW_PASSED$'; then
    review_passed=true
    log_phase "iter $review_num: REVIEW_PASSED"
  else
    log_phase "iter $review_num: REVIEW_FAILED"
  fi

  final_review_file="$review_file"
  final_review_log_file="$review_log_file"
  review_num=$((review_num + 1))
done

END_TIME="$(date +%s)"
DURATION=$(( END_TIME - START_TIME ))

if $review_passed; then
  verdict="PASSED"
  exit_code=0
else
  verdict="FAILED"
  exit_code=1
fi

TASK_FILE_SUMMARY="$TASK_FILE"
if [[ -z "$TASK_FILE_SUMMARY" && -f "$RUN_TASK_FILE" ]]; then
  TASK_FILE_SUMMARY="$RUN_TASK_FILE"
elif [[ -z "$TASK_FILE_SUMMARY" ]]; then
  TASK_FILE_SUMMARY="n/a (manual rerun)"
fi

cat >"$ARTIFACTS/summary.md" <<EOF
# develop-review-loop summary

- Task file: $TASK_FILE_SUMMARY
- Iterations used: $review_num / $MAX
- Verdict: $verdict
- Start ref: $START_REF
- Start stage: $ORIGINAL_START_STAGE
- Manual rerun: $MANUAL_RERUN_ENABLED
- Rerun start: ${LOOP_START_STAGE}-${START_REVIEW_NUM}
- Duration: ${DURATION}s
- Run directory: $ARTIFACTS
- Retained run directories: $KEEP_RUNS
- Development agent: $DEV_AGENT ($(agent_bin "$DEV_AGENT"))
- Review agent: $REVIEW_AGENT ($(agent_bin "$REVIEW_AGENT"))

Final review file: $final_review_file
Final review log: $final_review_log_file
Inspect cumulative changes: \`git diff $START_REF\`
EOF

log_phase "usage summary: start"
if append_usage_summary "$ARTIFACTS/summary.md" "$ARTIFACTS"; then
  log_phase "usage summary: done"
else
  log_phase "usage summary: skipped (failed to parse usage metadata)"
fi

cleanup_old_runs "$ARTIFACTS_ROOT" "$KEEP_RUNS" "$ARTIFACTS"
log_phase "$verdict in $review_num iteration(s); summary at $ARTIFACTS/summary.md"
exit $exit_code
